#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
OUTPUT_DIR="$HOME/.claude/behaviors"
SEL_DIR="$OUTPUT_DIR/.selections"
mkdir -p "$OUTPUT_DIR" "$SEL_DIR"

die() { echo "error: $*" >&2; exit 1; }

list_behaviors() {
  for d in "$SCRIPT_DIR"/*/; do
    [ -f "$d/template" ] && basename "$d"
  done | sort
}

case "${1:-}" in
  ""|-h|--help)
    cat <<EOF
Usage: configure <behavior> [--knob=value ...]
       configure --list

Generates a Claude-optimized behavior file into ~/.claude/behaviors/.
Run without knob args for interactive mode (shows descriptions, remembers choices).

  configure tdd --school=st-pauli --cycle_speed=micro
  configure tdd                    # interactive
  configure tdd --show             # show saved selections
  configure tdd --reset            # forget saved, prompt fresh

Available behaviors:
$(list_behaviors | sed 's/^/  /')
EOF
    exit 0
    ;;
  --list) list_behaviors; exit 0 ;;
esac

BEHAVIOR="$1"; shift
BDIR="$SCRIPT_DIR/$BEHAVIOR"
[ -d "$BDIR" ] || die "unknown behavior: $BEHAVIOR"
[ -f "$BDIR/template" ] || die "no template for: $BEHAVIOR"

KNOBS_FILE="$BDIR/knobs"
SEL_FILE="$SEL_DIR/$BEHAVIOR"

# --- Parse knobs file ---
declare -a KNOB_ORDER=()
declare -A KNOB_PROMPTS=() KNOB_MULTI=() KNOB_OPTIONS=() KNOB_OPT_ORDER=()

if [ -f "$KNOBS_FILE" ] && [ -s "$KNOBS_FILE" ]; then
  cur=""
  while IFS= read -r line || [ -n "$line" ]; do
    [[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && continue
    if [[ ! "$line" =~ ^[[:space:]] ]]; then
      multi=0; name="${line%%:*}"
      [[ "$name" == +* ]] && { multi=1; name="${name#+}"; }
      cur="$name"
      KNOB_ORDER+=("$name")
      KNOB_PROMPTS["$name"]="${line#*: }"
      KNOB_MULTI["$name"]="$multi"
      KNOB_OPT_ORDER["$name"]=""
    else
      trimmed="${line#"${line%%[![:space:]]*}"}"
      opt="${trimmed%%:*}"; desc="${trimmed#*: }"
      KNOB_OPTIONS["${cur}.${opt}"]="$desc"
      KNOB_OPT_ORDER["$cur"]+="${opt} "
    fi
  done < "$KNOBS_FILE"
fi

# --- --show ---
if [[ "${1:-}" == "--show" ]]; then
  [ -f "$SEL_FILE" ] && cat "$SEL_FILE" || echo "No saved selections."
  exit 0
fi

# --- No knobs? Just copy template ---
if [ ${#KNOB_ORDER[@]} -eq 0 ]; then
  cp "$BDIR/template" "$OUTPUT_DIR/${BEHAVIOR}.md"
  echo "Generated: $OUTPUT_DIR/${BEHAVIOR}.md (no knobs)"
  exit 0
fi

# --- Load saved defaults ---
declare -A DEFAULTS=()
if [ -f "$SEL_FILE" ] && [[ "${*}" != *"--reset"* ]]; then
  while IFS='=' read -r k v; do
    [[ -n "$k" && ! "$k" =~ ^# ]] && DEFAULTS["$k"]="$v"
  done < "$SEL_FILE"
fi

# --- Collect selections ---
declare -A SELECTIONS=()
for arg in "$@"; do
  [[ "$arg" == "--reset" ]] && DEFAULTS=()
  [[ "$arg" =~ ^--([a-zA-Z_-]+)=(.+)$ ]] && SELECTIONS["${BASH_REMATCH[1]}"]="${BASH_REMATCH[2]}"
done

# Interactive for missing knobs
for knob in "${KNOB_ORDER[@]}"; do
  [ -n "${SELECTIONS[$knob]:-}" ] && continue
  multi="${KNOB_MULTI[$knob]}"
  read -ra opts <<< "${KNOB_OPT_ORDER[$knob]}"
  default="${DEFAULTS[$knob]:-}"

  echo ""
  echo -e "\033[1m${KNOB_PROMPTS[$knob]}\033[0m"
  for i in "${!opts[@]}"; do
    opt="${opts[$i]}"; desc="${KNOB_OPTIONS["${knob}.${opt}"]}"
    mark="  "
    if [ -n "$default" ]; then
      [[ "$multi" == "1" && ",$default," == *",$opt,"* ]] && mark="* "
      [[ "$multi" == "0" && "$default" == "$opt" ]] && mark="* "
    fi
    printf "  ${mark}%d) %-22s %s\n" "$((i+1))" "$opt" "— $desc"
  done

  if [ "$multi" = "1" ]; then
    hint="comma-separated, e.g. 1,3"; [ -n "$default" ] && hint+="; enter=keep *"
    read -rp "Select ($hint): " choice
    if [ -z "$choice" ] && [ -n "$default" ]; then
      SELECTIONS["$knob"]="$default"
    else
      sel=(); IFS=',' read -ra idxs <<< "$choice"
      for idx in "${idxs[@]}"; do
        idx="${idx// /}"
        [[ "$idx" =~ ^[0-9]+$ && "$idx" -ge 1 && "$idx" -le "${#opts[@]}" ]] && sel+=("${opts[$((idx-1))]}")
      done
      SELECTIONS["$knob"]="$(IFS=,; echo "${sel[*]}")"
    fi
  else
    hint="1-${#opts[@]}"; [ -n "$default" ] && hint+="; enter=keep *"
    while true; do
      read -rp "Select ($hint): " choice
      [ -z "$choice" ] && [ -n "$default" ] && { SELECTIONS["$knob"]="$default"; break; }
      [[ "$choice" =~ ^[0-9]+$ && "$choice" -ge 1 && "$choice" -le "${#opts[@]}" ]] && \
        { SELECTIONS["$knob"]="${opts[$((choice-1))]}"; break; }
      echo "Invalid."
    done
  fi
done

# --- Save selections ---
: > "$SEL_FILE"
for knob in "${KNOB_ORDER[@]}"; do
  echo "${knob}=${SELECTIONS[$knob]}" >> "$SEL_FILE"
done

# --- Generate ---
OUTPUT=$(<"$BDIR/template")
for knob in "${KNOB_ORDER[@]}"; do
  val="${SELECTIONS[$knob]}"
  if [[ "$val" == *,* ]]; then
    parts=(); IFS=',' read -ra vs <<< "$val"
    for v in "${vs[@]}"; do
      d="${KNOB_OPTIONS["${knob}.${v}"]:-$v}"
      parts+=("$v ($d)")
    done
    desc="$(IFS='; '; echo "${parts[*]}")"
  else
    desc="${KNOB_OPTIONS["${knob}.${val}"]:-$val}"
  fi
  OUTPUT="${OUTPUT//\$\{${knob}\}/$desc}"
  OUTPUT="${OUTPUT//\$\{${knob}_name\}/$val}"
done

OUT="$OUTPUT_DIR/${BEHAVIOR}.md"
printf '%s\n' "$OUTPUT" > "$OUT"
echo "Generated: $OUT"
